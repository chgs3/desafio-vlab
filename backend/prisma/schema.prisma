generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model LessonPlan {
  id               String   @id @default(uuid())
  title            String
  objective        String
  summary          String
  plannedDate      DateTime
  discipline       String
  contents         Json
  supportResources Json
  tags             Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}